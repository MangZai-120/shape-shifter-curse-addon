{
    "type": "apoli:multiple",
    "regen_pause_timer": {
        "type": "apoli:resource",
        "min": 0,
        "max": 120,
        "start_value": 0,
        "hud_render": {
            "should_render": false
        }
    },
    "pause_tick": {
        "type": "apoli:action_over_time",
        "interval": 1,
        "condition": {
            "type": "apoli:resource",
            "resource": "*:*_regen_pause_timer",
            "comparison": ">",
            "compare_to": 0
        },
        "entity_action": {
            "type": "apoli:change_resource",
            "resource": "*:*_regen_pause_timer",
            "operation": "add",
            "change": -1
        }
    },
    "regen": {
        "type": "apoli:action_over_time",
        "interval": 60,
        "condition": {
            "type": "apoli:and",
            "conditions": [
                {
                    "type": "ssc_addon:skill_disabled",
                    "form": "familiar_fox",
                    "skill": "mana_regen"
                },
                {
                    "type": "apoli:resource",
                    "resource": "*:*_regen_pause_timer",
                    "comparison": "==",
                    "compare_to": 0
                }
            ]
        },
        "entity_action": {
            "type": "shape-shifter-curse:gain_mana",
            "mana": 1.0
        }
    }
}

{
  "type": "origins:action_over_time",
  "interval": 20,
  "condition": {
    "type": "origins:and",
    "conditions": [
      {
        "type": "origins:resource",
        "resource": "my_addon:form_allay_sp_jukebox_active",
        "comparison": "==",
        "compare_to": 1
      },
      {
        "type": "origins:resource",
        "resource": "my_addon:form_allay_sp_jukebox_mode",
        "comparison": "==",
        "compare_to": 0
      }
    ]
  },
  "entity_action": {
    "type": "origins:resource",
    "resource": "my_addon:form_allay_sp_jukebox_speed_execute",
    "operation": "set",
    "change": 1
  }
}
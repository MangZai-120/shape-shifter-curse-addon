{
    "type": "apoli:multiple",
    "cooldown_resource": {
        "type": "apoli:resource",
        "min": 0,
        "max": 100,
        "start_value": 0,
        "hud_render": {
            "should_render": false
        }
    },
    "tick_cooldown": {
        "type": "apoli:action_over_time",
        "interval": 1,
        "condition": {
            "type": "apoli:resource",
            "resource": "my_addon:form_snow_fox_sp_frost_regen_cooldown_resource",
            "comparison": ">",
            "compare_to": 0
        },
        "entity_action": {
            "type": "apoli:change_resource",
            "resource": "my_addon:form_snow_fox_sp_frost_regen_cooldown_resource",
            "change": -1
        }
    },
    "reset_cooldown_on_hit": {
        "type": "apoli:action_when_damage_taken",
        "entity_action": {
            "type": "apoli:change_resource",
            "resource": "my_addon:form_snow_fox_sp_frost_regen_cooldown_resource",
            "change": 100,
            "operation": "set"
        },
        "cooldown": 0
    },
    "natural_regen": {
        "type": "apoli:action_over_time",
        "interval": 20,
        "condition": {
            "type": "apoli:and",
            "conditions": [
                {
                    "type": "ssc_addon:skill_disabled",
                    "form": "snow_fox",
                    "skill": "frost_regen"
                },
                {
                    "type": "apoli:resource",
                    "resource": "my_addon:form_snow_fox_sp_frost_regen_cooldown_resource",
                    "comparison": "==",
                    "compare_to": 0
                }
            ]
        },
        "entity_action": {
            "type": "apoli:if_else",
            "condition": {
                "type": "apoli:or",
                "conditions": [
                    {
                        "type": "apoli:and",
                        "conditions": [
                            {
                                "type": "apoli:biome",
                                "condition": {
                                    "type": "apoli:temperature",
                                    "comparison": "<",
                                    "compare_to": 0.15
                                }
                            },
                            {
                                "type": "ssc_addon:has_reverse_thermometer",
                                "inverted": true
                            }
                        ]
                    },
                    {
                        "type": "apoli:and",
                        "conditions": [
                            {
                                "type": "apoli:or",
                                "conditions": [
                                    {
                                        "type": "apoli:biome",
                                        "condition": {
                                            "type": "apoli:temperature",
                                            "comparison": ">=",
                                            "compare_to": 1.0
                                        }
                                    },
                                    {
                                        "type": "apoli:dimension",
                                        "dimension": "minecraft:the_nether"
                                    }
                                ]
                            },
                            {
                                "type": "ssc_addon:has_reverse_thermometer"
                            }
                        ]
                    }
                ]
            },
            "if_action": {
                "type": "apoli:change_resource",
                "resource": "my_addon:form_snow_fox_sp_resource",
                "change": 5
            },
            "else_action": {
                "type": "apoli:change_resource",
                "resource": "my_addon:form_snow_fox_sp_resource",
                "change": 3
            }
        }
    }
}

{
    "type": "origins:multiple",
    "charging_state": {
        "type": "origins:resource",
        "min": 0,
        "max": 1,
        "start_value": 0,
        "hud_render": {
            "should_render": false
        }
    },
    "charge_timer": {
        "type": "origins:resource",
        "min": 0,
        "max": 20,
        "start_value": 0,
        "hud_render": {
            "should_render": true,
            "bar_index": 5,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_charge_timer",
                "comparison": ">",
                "compare_to": 0
            }
        }
    },
    "cooldown_timer": {
        "type": "origins:resource",
        "min": 0,
        "max": 400,
        "start_value": 0,
        "hud_render": {
            "should_render": true,
            "bar_index": 6,
            "condition": {
                "type": "origins:resource",
                "resource": "*:*_cooldown_timer",
                "comparison": ">",
                "compare_to": 0
            }
        }
    },
    "cooldown_tick": {
        "type": "origins:action_over_time",
        "interval": 1,
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "*:*_cooldown_timer",
            "change": -1,
            "operation": "add"
        },
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_cooldown_timer",
            "comparison": ">",
            "compare_to": 0
        }
    },
    "key_activation": {
        "type": "origins:active_self",
        "key": {
            "key": "key.ssc_addon.sp_secondary"
        },
        "cooldown": 20,
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_charging_state",
                    "change": 1,
                    "operation": "set"
                },
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_charge_timer",
                    "change": 0,
                    "operation": "set"
                },
                {
                    "type": "origins:execute_command",
                    "command": "playsound entity.warden.heartbeat hostile @a ~ ~ ~ 1.5 0.5"
                },
                {
                    "type": "origins:apply_effect",
                    "effect": {
                        "effect": "minecraft:slowness",
                        "duration": 30,
                        "amplifier": 3,
                        "is_ambient": true,
                        "show_particles": false,
                        "show_icon": false
                    }
                }
            ]
        },
        "condition": {
            "type": "origins:and",
            "conditions": [
                {
                    "type": "origins:resource",
                    "resource": "*:*_cooldown_timer",
                    "comparison": "==",
                    "compare_to": 0
                },
                {
                    "type": "origins:resource",
                    "resource": "*:*_charging_state",
                    "comparison": "==",
                    "compare_to": 0
                }
            ]
        }
    },
    "tick_charging": {
        "type": "origins:action_over_time",
        "interval": 1,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_charging_state",
            "comparison": "==",
            "compare_to": 1
        },
        "entity_action": {
            "type": "origins:change_resource",
            "resource": "*:*_charge_timer",
            "change": 1,
            "operation": "add"
        }
    },
    "charging_particles": {
        "type": "origins:action_over_time",
        "interval": 4,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_charging_state",
            "comparison": "==",
            "compare_to": 1
        },
        "entity_action": {
            "type": "origins:execute_command",
            "command": "particle minecraft:smoke ~ ~1 ~ 0.3 0.5 0.3 0.02 8 force @a"
        }
    },
    "trigger_scream": {
        "type": "origins:action_over_time",
        "interval": 1,
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_charge_timer",
            "comparison": ">=",
            "compare_to": 20
        },
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_charging_state",
                    "change": 0,
                    "operation": "set"
                },
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_charge_timer",
                    "change": 0,
                    "operation": "set"
                },
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_cooldown_timer",
                    "change": 400,
                    "operation": "set"
                },
                {
                    "type": "origins:clear_effect",
                    "effect": "minecraft:slowness"
                },
                {
                    "type": "origins:execute_command",
                    "command": "playsound entity.warden.sonic_boom hostile @a ~ ~ ~ 2.0 1.5"
                },
                {
                    "type": "my_addon:fallen_allay_scream"
                },
                {
                    "type": "origins:execute_command",
                    "command": "particle minecraft:sonic_boom ~ ~1 ~ 0 0 0 0 1 force @a"
                },
                {
                    "type": "origins:execute_command",
                    "command": "particle minecraft:sculk_soul ~ ~1 ~ 3.0 2.0 3.0 0.05 30 force @a"
                },
                {
                    "type": "origins:execute_command",
                    "command": "particle minecraft:large_smoke ~ ~1 ~ 2.0 1.5 2.0 0.03 20 force @a"
                },
                {
                    "type": "shape-shifter-curse:spawn_particles_in_circle",
                    "particle": "minecraft:sculk_soul",
                    "count": 1,
                    "speed": 0.02,
                    "force": true,
                    "spread": {
                        "x": 0.3,
                        "y": 0.3,
                        "z": 0.3
                    },
                    "radius": 25.0,
                    "sample_count": 48
                }
            ]
        }
    },
    "interrupt_on_damage": {
        "type": "origins:action_when_damage_taken",
        "entity_action": {
            "type": "origins:and",
            "actions": [
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_charging_state",
                    "operation": "set",
                    "change": 0
                },
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_charge_timer",
                    "operation": "set",
                    "change": 0
                },
                {
                    "type": "origins:change_resource",
                    "resource": "*:*_cooldown_timer",
                    "operation": "set",
                    "change": 100
                },
                {
                    "type": "origins:clear_effect",
                    "effect": "minecraft:slowness"
                },
                {
                    "type": "origins:play_sound",
                    "sound": "block.beacon.deactivate",
                    "volume": 0.5,
                    "pitch": 1.5
                }
            ]
        },
        "condition": {
            "type": "origins:resource",
            "resource": "*:*_charging_state",
            "comparison": "==",
            "compare_to": 1
        }
    }
}
